{
  "name": "rommel-en-doe-wat-2",
  "private": true,
  "version": "0.9.0",
  "description": "Rommel en doe wat - lightweight PDM MVP for prototype engineering",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "node scripts/dev-electron.mjs",
    "build": "npm run build:renderer && npm run build:desktop",
    "build:renderer": "vite build",
    "build:desktop": "node -e \"require('node:fs').rmSync('dist-electron', { recursive: true, force: true })\" && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run --coverage",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "pack": "npm run build && node scripts/package-win.mjs --dir",
    "dist:win": "npm run build && node scripts/package-win.mjs --win nsis portable",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "pdm",
    "solidworks",
    "pwa",
    "engineering"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/geert-mol/rommel-en-doe-wat-2.git"
  },
  "author": "Geert Mol",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.geertmol.rndpdm",
    "productName": "Rommel en doe wat",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "geert-mol",
        "repo": "rommel-en-doe-wat-2",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "icon.ico",
      "verifyUpdateCodeSignature": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "Rommel-en-doe-wat-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Rommel-en-doe-wat-${version}-Portable.${ext}"
    }
  }
}
